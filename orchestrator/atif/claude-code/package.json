{
  "name": "@atif/claude-code",
  "version": "1.0.0",
  "description": "Convert Claude Code JSONL conversation logs to ATIF format",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
