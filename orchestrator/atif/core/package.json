{
  "name": "@atif/core",
  "version": "1.7.0",
  "description": "TypeScript types for Agent Trajectory Interchange Format (ATIF) v1.7",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "cd ../.. && npm run lint -- atif/core/"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  }
}
