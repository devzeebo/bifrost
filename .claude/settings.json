{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npx *)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch node ban-npx"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch typescript lint"
          }
        ]
      }
    ]
  }
}
