#!/bin/bash

set -e

INPUT=$(cat)

get_field() {
  local field="$1"
  local json="${2:-$INPUT}"
  echo "$json" | jq -r ".$field // empty" 2>/dev/null || echo ""
}

deny() {
  echo '{"hookSpecificOutput":{"hookEventName":"'$(get_field hook_event_name)'","permissionDecision":"deny","permissionDecisionReason":"'$1'"}}'

  exit 2
}

block() {
  echo '{"hookSpecificOutput":{"hookEventName":"'$(get_field hook_event_name)'","decision":"block","reason":"'$1'"}}' >&2

  exit 2
}

export -f get_field
export -f deny
export -f block
export INPUT

$CLAUDE_PROJECT_DIR/.claude/skills/$1/hooks/$(get_field hook_event_name).d/$2