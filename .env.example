# Environment configuration for Docker Compose
# Copy this file to .env and customize as needed

# PostgreSQL Configuration
POSTGRES_DB=bifrost
POSTGRES_USER=bifrost
POSTGRES_PASSWORD=bifrost123

# Bifrost Configuration
BIFROST_DB_DRIVER=postgres
BIFROST_DB_PATH=postgres://bifrost:bifrost123@postgres:5432/bifrost?sslmode=disable
BIFROST_PORT=8080

# Optional: Admin JWT signing key for production
# Generate a secure key with: openssl rand -base64 32
# ADMIN_JWT_SIGNING_KEY=your-base64-encoded-key-here

# Optional: Catch-up interval for projection engine
# BIFROST_CATCHUP_INTERVAL=1s